#!/usr/bin/env sh
# Husky pre-commit hook: run lint-staged (formatters) and abort on failure
echo "🔧 Running lint-staged..."

if command -v npx >/dev/null 2>&1; then
  npx lint-staged
elif command -v pnpm >/dev/null 2>&1; then
  pnpm -s lint-staged
elif command -v yarn >/dev/null 2>&1; then
  yarn -s lint-staged
else
  echo "⚠️  lint-staged not available. Install dependencies and run 'npx husky install'" >&2
  exit 1
fi

status=$?
if [ $status -ne 0 ]; then
  echo "❌ lint-staged failed (status $status). Aborting commit." >&2
  exit $status
fi

# success — allow commit to proceed (tests are run on pre-push)
exit 0
